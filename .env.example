CODEX_VERSION=0.144.1
CODEX_DEFAULT_MODEL=gpt-5.6-luna
CODEX_EXEC_FALLBACK=true
# Recycle each pooled codex app-server child after this many turns to bound the
# memory the native process accumulates over its life. 0 disables recycling.
CODEX_APP_SERVER_MAX_TURNS=100
# Attachment-friendly defaults; lower these for less-trusted clients.
CODEX_MAX_REQUEST_BODY_BYTES=20971520
CODEX_MAX_PROMPT_BYTES=16777216
RUST_LOG=info
DOCKER_NETWORK=homelab
# Use the host trust store so Codex can validate the upstream TLS certificate.
HOST_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
